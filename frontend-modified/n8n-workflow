        "jsCode": "const html = $json.body || $json.data || $json.html || '';\n\nif (!html) {\n  return [{ json: { cleanedHtml: '', error: 'No HTML found in input' } }];\n}\n\nlet cleaned = html;\n\n// Remove only very low-risk content\ncleaned = cleaned.replace(/<!--[\\s\\S]*?-->/g, ''); // comments\ncleaned = cleaned.replace(/<style\\b[^>]*>[\\s\\S]*?<\\/style>/gi, '');\ncleaned = cleaned.replace(/<noscript\\b[^>]*>[\\s\\S]*?<\\/noscript>/gi, '');\ncleaned = cleaned.replace(/<svg\\b[^>]*>[\\s\\S]*?<\\/svg>/gi, '');\n\n// Keep all scripts because some sites store product data there\n// especially window.__INITIAL_STATE__, __NEXT_DATA__, etc.\n\n// Collapse whitespace a bit\ncleaned = cleaned\n  .replace(/\\s{2,}/g, ' ')\n  .replace(/>\\s+</g, '><')\n  .trim();\n\nreturn [{\n  json: {\n    originalLength: html.length,\n    cleanedLength: cleaned.length,\n    reductionPercent: Math.round((1 - cleaned.length / html.length) * 100),\n    cleanedHtml: cleaned\n  }\n}];"
