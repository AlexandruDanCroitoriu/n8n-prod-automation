    {
      "parameters": {
        "jsCode": "function normalize(url) {\n  if (!url || typeof url !== 'string') return null;\n  let u = url.trim();\n  if (u.startsWith('//')) u = 'https:' + u;\n  return u;\n}\n\nfunction baseKey(url) {\n  return url\n    .toLowerCase()\n    .replace(/_\\d+x\\d+(?=\\.\\w+(\\?|$))/, '')   // Shopify sizes\n    .replace(/-\\d+x\\d+(?=\\.\\w+(\\?|$))/, '')   // Woo sizes\n    .replace(/@2x(?=\\.\\w+(\\?|$))/, '')        // Retina suffix\n    .replace(/_grande(?=\\.\\w+(\\?|$))/, '')    // Shopify grande\n    .replace(/\\?.*$/, '');                    // Remove query\n}\n\nfunction score(url) {\n  const u = url.toLowerCase();\n  let s = 0;\n\n  if (/@2x(?=\\.\\w+(\\?|$))/.test(u)) s += 60;\n  if (/(2048x2048|2048x1860)/.test(u)) s += 80;\n  else if (/(1728x1728|1728x1569)/.test(u)) s += 70;\n  else if (/(1512x1512|1512x1373)/.test(u)) s += 60;\n  else if (/(1296x1296|1296x1177)/.test(u)) s += 50;\n  else if (/(1200x1200|1080x1080|1080x981)/.test(u)) s += 40;\n  else if (/(900x900|900x817)/.test(u)) s += 30;\n  else if (/(720x720|720x654)/.test(u)) s += 20;\n  else if (/(540x540|540x490)/.test(u)) s += 10;\n\n  if (u.includes('_grande')) s += 35;\n  if (u.includes('original') || u.includes('master')) s += 90;\n\n  if (/(180x180|180x163|360x360|360x327|100x100|120x120|150x150|200x200|240x240|300x300)/.test(u)) s -= 100;\n  if (/(icon|logo|sprite|badge|avatar|banner|thumb|placeholder)/.test(u)) s -= 150;\n\n  return s;\n}\n\nreturn items.map(item => {\n  const raw = (item.json.output?.product_image_links || [])\n    .map(normalize)\n    .filter(Boolean);\n\n  const groups = new Map();\n\n  for (const url of raw) {\n    const key = baseKey(url);\n    const sc = score(url);\n\n    if (!groups.has(key) || sc > groups.get(key).score) {\n      groups.set(key, { url, score: sc });\n    }\n  }\n\n  const best = [...groups.values()]\n    .sort((a, b) => b.score - a.score)\n    .map(x => x.url);\n\n  item.json.output.product_image_links = best;\n  return item;\n});"
      },
