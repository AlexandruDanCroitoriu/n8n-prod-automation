        "jsCode": "const rawOwnerId = $('Create Product').first().json.data.productSet.product.id;\nconst rawMetafields = $('Get a row4').first().json.metafields;\n\nfunction normalizeProductGid(raw) {\n  if (!raw) {\n    throw new Error('Missing product id');\n  }\n\n  const value = String(raw).trim();\n\n  if (value.startsWith('gid://shopify/Product/')) {\n    return value;\n  }\n\n  return `gid://shopify/Product/${value}`;\n}\n\nfunction parseMetafields(raw) {\n  if (Array.isArray(raw)) {\n    return raw;\n  }\n\n  if (typeof raw === 'string') {\n    const parsed = JSON.parse(raw);\n\n    if (!Array.isArray(parsed)) {\n      throw new Error('Metafields is not a valid JSON array');\n    }\n\n    return parsed;\n  }\n\n  throw new Error('Invalid metafields format');\n}\n\nfunction stripHtml(value) {\n  if (value == null) return '';\n  return String(value)\n    .replace(/<h[1-6][^>]*>/gi, '')\n    .replace(/<\\/h[1-6]>/gi, '\\n')\n    .replace(/<p[^>]*>/gi, '')\n    .replace(/<\\/p>/gi, '\\n')\n    .replace(/<br\\s*\\/?>/gi, '\\n')\n    .replace(/<li[^>]*>/gi, '• ')\n    .replace(/<\\/li>/gi, '\\n')\n    .replace(/<ul[^>]*>/gi, '')\n    .replace(/<\\/ul>/gi, '\\n')\n    .replace(/<ol[^>]*>/gi, '')\n    .replace(/<\\/ol>/gi, '\\n')\n    .replace(/<[^>]+>/g, '')\n    .replace(/&nbsp;/g, ' ')\n    .replace(/&amp;/g, '&')\n    .replace(/&quot;/g, '\"')\n    .replace(/&#39;/g, \"'\")\n    .replace(/\\n{3,}/g, '\\n\\n')\n    .trim();\n}\n\nfunction htmlToShopifyRichText(value) {\n  const text = stripHtml(value);\n\n  const paragraphs = text\n    .split(/\\n\\n+/)\n    .map(p => p.trim())\n    .filter(Boolean)\n    .map(p => ({\n      type: 'paragraph',\n      children: [\n        {\n          type: 'text',\n          value: p,\n        },\n      ],\n    }));\n\n  return JSON.stringify({\n    type: 'root',\n    children: paragraphs.length\n      ? paragraphs\n      : [\n          {\n            type: 'paragraph',\n            children: [\n              {\n                type: 'text',\n                value: '',\n              },\n            ],\n          },\n        ],\n  });\n}\n\nfunction formatMetafieldValue(key, type, value) {\n  if (key === 'tabel_specificatii_tehnice_multiline') {\n    return value == null ? '' : String(value).trim();\n  }\n\n  if (type === 'rich_text_field') {\n    return htmlToShopifyRichText(value);\n  }\n\n  if (type === 'single_line_text_field') {\n    return stripHtml(value).replace(/\\n+/g, ' ').trim().slice(0, 255);\n  }\n\n  if (type === 'multi_line_text_field') {\n    return stripHtml(value);\n  }\n\n  if (type === 'file_reference') {\n    return value == null ? '' : String(value).trim();\n  }\n\n  return value ?? '';\n}\n\nconst ownerId = normalizeProductGid(rawOwnerId);\n\nconst metafields = parseMetafields(rawMetafields).map((item) => ({\n  ownerId,\n  namespace: item.namespace || 'custom',\n  key: item.key,\n  type: item.type,\n  value: formatMetafieldValue(item.key, item.type, item.value),\n}));\n\nreturn [\n  {\n    json: {\n      variables: {\n        metafields,\n      },\n    },\n  },\n];"
